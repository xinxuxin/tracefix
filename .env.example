# TraceFix environment example
# All values are optional. The local CLI can also run with defaults or a JSON config file.

TRACEFIX_CONFIG=config/settings.example.json
TRACEFIX_MAX_ATTEMPTS=2
TRACEFIX_TIMEOUT_SECONDS=2
TRACEFIX_TRACE_DIR=logs/traces
TRACEFIX_PATCH_DIR=outputs/patches
TRACEFIX_LOG_DIR=logs
TRACEFIX_EVALUATION_DIR=evaluation
TRACEFIX_PROVIDER_MODE=local
TRACEFIX_PROVIDER_MODEL=
TRACEFIX_OPENAI_MODEL=gpt-4.1
TRACEFIX_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
TRACEFIX_API_TIMEOUT_SECONDS=20
TRACEFIX_API_MAX_TOKENS=1200
TRACEFIX_ENABLE_LLM_DIAGNOSER=0
TRACEFIX_ENABLE_LLM_PATCHER=0
TRACEFIX_ENABLE_LLM_VERIFIER_ASSIST=0
TRACEFIX_FALLBACK_TO_LOCAL_ON_PROVIDER_ERROR=1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
