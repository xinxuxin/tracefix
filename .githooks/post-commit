#!/bin/sh

# Auto-push the current branch after each successful local commit.
# If the push fails, keep the commit and show a short warning.

branch_name="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"

if [ -z "$branch_name" ]; then
  exit 0
fi

git push origin "$branch_name"
status=$?

if [ "$status" -ne 0 ]; then
  echo "TraceFix hook: auto-push failed for branch '$branch_name'." >&2
  exit 0
fi

exit 0
